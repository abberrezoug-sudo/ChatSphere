{
  "name": "chatsphere",
  "version": "1.0.0",
  "description": "A real-time chat server built with Node.js, TypeScript, and WebSocket.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch server/src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "websocket",
    "ws",
    "nodejs",
    "typescript",
    "chat",
    "realtime"
  ],
  "author": "Abdellah Berrezoug",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
